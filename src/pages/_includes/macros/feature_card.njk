{% from "macros/image_carousel.njk" import image_carousel %}

{% macro feature_card(title, description, images, id, img_width) %}
{% set txt_width = 12 - img_width %}
<div class="col-lg-6 mb-4">
  <div class="card border-1 h-100 shadow-lg" id="featCard_{{ id }}">
    <h2 class="card-header text-center bg-white fs-4 fw-bold">{{ title }}</h2>
    <div class="card-body p-2 p-lg-4">
      <div class="row">
        <div class="mouseoverlink col-lg-{{ img_width }}">
          {{ image_carousel(images, "featCarousel_" + id, "#" + id) }}
        </div>
        <div class="col-lg-{{ txt_width }}">
          <p>{{ description | safe }}</p>
        </div>
      </div>
    </div>
  </div>
</div>
{% endmacro %}

{% macro modal_feature_card(title, description, images, id) %}
<div class="modal fade" id="{{ id }}" tabindex="-1" aria-labelledby="modalFeatTitle_{{ id }}" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-body">
        <div class="card border-1 h-100 shadow-lg" id="{{ id }}">
          <h2 class="card-header text-center bg-white fs-4 fw-bold">{{ title }}</h2>
          <div class="card-body p-2 p-lg-4">
            <div class="row">
              <div class="col-lg-12 mb-4">
                {{ image_carousel(images, "modalFeatCarousel_" + id) }}
              </div>
              <div class="col-lg-12 mb-4">
                <p>{{ description | safe }}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>
{% endmacro %}
