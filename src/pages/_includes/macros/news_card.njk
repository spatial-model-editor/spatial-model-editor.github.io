{% macro news_card(title, date, url, description) %}
<div class="row align-items-center row-cols-1">
  <div class="col-lg-12 col-xxl-12 mb-5">
    <div class="card border-1 shadow-lg">
      <div class="card-header text-center bg-white fs-4 fw-bold">
        <div class="row align-items-center">
          <div class="col text-start">
            <div class="btn disabled btn-outline-primary">
              <i class="bi bi-calendar"></i> {{ date }}
            </div>
          </div>
          <div class="col">
            <h2 class="mb-0 fs-4 fw-bold">{{ title }}</h2>
          </div>
          <div class="col text-end">
            <a class="btn btn-outline-primary" href="{{ url }}" role="button">
              <i class="bi bi-box-arrow-up-right"></i> More information
            </a>
          </div>
        </div>
      </div>
      <div class="card-body p-2 p-lg-3">
        <div class="row">
          <div class="col my-auto">
            <div>{{ description | safe }}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{% endmacro %}
